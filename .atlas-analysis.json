  "keyFeatures": [
    "Gen1: Lightweight binary JSON with proto-tensor support (11 core types)",
    "Gen2: Full codec with dictionary coding, compression, and ML extensions (18+ types)",
    "Multi-language SDKs: Go, Rust, Python, TypeScript, C with identical wire format",
    "Graph data structures: Node, Edge, NodeBatch, EdgeBatch, GraphShard for GNN workloads",
    "ML types: Native Tensor, Image, Audio types for ML pipelines",
    "Streaming support: Record-by-record (Gen1) and framed master streams (Gen2)",
    "Dictionary coding: ~50% size reduction for repeated schemas in Gen2",
    "Compression: Optional gzip/zstd compression for Gen2",
    "CLI tool: Command-line utility for encoding, decoding, and inspection",
    "Security limits: Configurable limits to prevent memory exhaustion"
  ],
  "publicApiSurface": [
    "gen1.Encode(data) / gen1.Decode(data)",
    "gen2.Encode(value, opts) / gen2.Decode(data, opts)",
    "gen1.NewStreamDecoder(reader)",
    "gen2.NewMasterFrame(data)",
    "gen2.NewColumnReader(data)",
    "gen2.Node(config) / gen2.Edge(config)",
    "gen2.GraphShard(nodes, edges, metadata)",
    "gen2.Tensor(dtype, shape, data)",
    "gen2.Image(format, width, height, data)",
    "gen2.Audio(encoding, sampleRate, channels, data)",
    "cowrie encode [--gen1|--gen2] [--compress=type]",
    "cowrie decode",
    "cowrie info"
  ]
